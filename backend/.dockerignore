# Byte-compiled / cache files
__pycache__/
*.py[cod]
*$py.class

#Dockerfile so that it doesn't get copied into the image
Dockerfile

# Distribution / packaging
build/
dist/
*.egg-info/

# Virtual environments
env/
venv/
.venv/
ENV/
env.bak/

# Python tooling caches
.mypy_cache/
.pytest_cache/
.coverage
.cache/

# IDE / editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db

# Git
.git

# Node / frontend
node_modules/

# Logs
npm-debug.log
yarn-debug.log
yarn-error.log

# Local/secrets files (keep out of image if you prefer; note: Dockerfile currently copies backend/.env)
.env.local
.env.*.local

# Coverage and reports
htmlcov/
coverage.xml

# Optional: exclude tests from image
tests/

# End of file
